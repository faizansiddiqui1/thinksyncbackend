# Server Configuration
PORT=5000
NODE_ENV=development
# AES-256-GCM key: 32 bytes encoded as 64 hex chars
CRYPTO_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# MongoDB
MONGODB_URI=mongodb://localhost:27017/auth_system

# JWT Configuration
JWT_ACCESS_SECRET=your_access_token_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MSG91 Configuration
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=your_sender_id
MSG91_ROUTE=4
MSG91_OTP_TEMPLATE_ID=your_template_id

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5
